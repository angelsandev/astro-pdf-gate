---
import Layout from "../layouts/Layout.astro";
import PdfCard from "../components/PdfCard.astro";
import { dataPdfs } from "../data/documentos.js";

const fichaPdfs = dataPdfs.filter(item => item.type === "Ficha de Datos");

const title = "Fichas de Datos PDF"
---


  <Layout title={title}>
    <section class="grid-pdfs">
      {
        fichaPdfs.map((item) => (
          <PdfCard
            title={item.title}
            type={item.type}
            size={item.size}
            url={item.url}
          ></PdfCard>
        ))
      }
    </section>
  </Layout>
