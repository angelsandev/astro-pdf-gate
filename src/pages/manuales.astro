---
import Layout from "../layouts/Layout.astro";
import PdfCard from "../components/PdfCard.astro";

const misPdfs = [
  {
    title: "Título documento 1",
    type: "Manual",
    size: "300KB",
    url: "/pdfs/UP5.2. Creación de usuarios para acceso remoto al servidor FTP - CE4.b).pdf",
  },
  {
    title: "Título documento 2",
    type: "Manual",
    size: "120KB",
    url: "/pdfs/UP5.3. Acceso al servidor en modo activo y pasivo - CE4.c).pdf",
  },
  {
    title: "Título documento 3",
    type: "Manual",
    size: "320KB",
    url: "/pdfs/UP5.2. Creación de usuarios para acceso remoto al servidor FTP - CE4.b).pdf",
  },
  {
    title: "Título documento 4",
    type: "Manual",
    size: "120KB",
    url: "/pdfs/UP5.3. Acceso al servidor en modo activo y pasivo - CE4.c).pdf",
  },
];

const title = "Manuales PDF"
---


  <Layout title={title}>
    <section class="grid-pdfs">
      {
        misPdfs.map((item) => (
          <PdfCard
            title={item.title}
            type={item.type}
            size={item.size}
            url={item.url}
          ></PdfCard>
        ))
      }
    </section>
  </Layout>

