---
import Layout from "../layouts/Layout.astro";
import PdfCard from "../components/PdfCard.astro";
import type { PDFDocument } from "../types/pdf";
//import { dataPdfs, type PDFDocument } from "../data/documentos";
//const fichaPdfs: PDFDocument[] = dataPdfs.filter(item => item.type === "Ficha de Datos");

const response = await fetch("http://localhost:3000/pdfs");
const allPdfs: PDFDocument[] = await response.json();
const fichaPdfs: PDFDocument[] = allPdfs.filter(
  (item) => item.type === "Ficha de Datos",
);
const title: string = "Fichas de Datos PDF";
const BACKEND_URL = "http://localhost:3000/manuales";
---

<Layout title={title}>
  <section class="grid-pdfs">
    {
      fichaPdfs.map((item) => (
        <PdfCard
          title={item.title}
          type={item.type}
          size={item.size}
          url={`${BACKEND_URL}/${item.url}`}
        />
      ))
    }
    {/* Mensaje de seguridad si no hay fichas */}
    {
      fichaPdfs.length === 0 && (
        <p class="text-center">
          No se encontraron fichas de datos disponibles.
        </p>
      )
    }
  </section>
</Layout>
